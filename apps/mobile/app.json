{
  "expo": {
    "name": "CrossFit Tracker",
    "slug": "crossfit-tracker",
    "version": "1.0.0",
    "scheme": "crossfit-tracker",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.payasoex.crossfittracker"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.payasoex.crossfittracker"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
