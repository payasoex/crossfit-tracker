{
  "expo": {
    "name": "CrossFit Tracker",
    "slug": "crossfit-tracker",
    "version": "1.0.0",
    "scheme": "crossfit-tracker",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.payasoex.crossfittracker"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.payasoex.crossfittracker"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "64e0da6f-0852-4564-9ab2-f30aaacfb52e"
      }
    }
  }
}
