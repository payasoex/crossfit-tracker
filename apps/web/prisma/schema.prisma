generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── AUTH (NextAuth.js v5) ─────────────────────────────────

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  weightUnit    WeightUnit @default(KG)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts        Account[]
  sessions        Session[]
  rmRecords       RMRecord[]
  wodLogs         WodLog[]
  customMovements Movement[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── MOVEMENTS ────────────────────────────────────────────

model Movement {
  id          String           @id @default(cuid())
  name        String
  nameEs      String?
  slug        String           @unique
  category    MovementCategory
  description String?         
  measureType MeasureType      @default(WEIGHT)
  isGlobal    Boolean          @default(false)
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  rmRecords RMRecord[]

  @@unique([name, createdById])
  @@map("movements")
}

// ── RM RECORDS ───────────────────────────────────────────

model RMRecord {
  id         String   @id @default(cuid())
  userId     String
  movementId String
  value      Float
  reps       Int?
  isPR       Boolean  @default(false)
  notes      String? 
  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movement Movement @relation(fields: [movementId], references: [id], onDelete: Restrict)

  @@index([userId, movementId])
  @@index([userId, isPR])
  @@index([userId, movementId, recordedAt])
  @@map("rm_records")
}

// ── WOD LOGS ─────────────────────────────────────────────

model WodLog {
  id              String   @id @default(cuid())
  userId          String
  name            String
  wodType         WodType
  description     String? 
  timeCap         Int?
  rounds          Int?
  timeSeconds     Int?
  totalReps       Int?
  roundsCompleted Int?
  loadKg          Float?
  scale           WodScale @default(RX)
  notes           String? 
  performedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, performedAt])
  @@index([userId, wodType])
  @@map("wod_logs")
}

// ── ENUMS ────────────────────────────────────────────────

enum WeightUnit {
  KG
  LB
}

enum MeasureType {
  WEIGHT
  REPS
}

enum MovementCategory {
  OLYMPIC_WEIGHTLIFTING
  POWERLIFTING
  GYMNASTICS
  MONOSTRUCTURAL
  FUNCTIONAL
}

enum WodType {
  FOR_TIME
  AMRAP
  EMOM
  LOAD
  CHIPPER
  CUSTOM
}

enum WodScale {
  RX
  SCALED
  RX_PLUS
}
